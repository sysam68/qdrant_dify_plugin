# Dify Plugin Development Environment Variables
# Copy this file to .env and fill in your actual values

# Method 1: Remote Debugging (Recommended for Dify Cloud)
INSTALL_METHOD=remote
REMOTE_INSTALL_URL=debug.dify.ai:5003
REMOTE_INSTALL_KEY=a5b2d2ff-417f-40b5-b56b-8b274f86e77f

# Method 2: Direct API Connection (Alternative)
# DIFY_API_HOST=https://cloud.dify.ai
# DIFY_API_KEY=your-api-key-here